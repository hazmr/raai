# Copy to .env and fill in. NEVER commit .env.

# --- HTTP ---
ADDR=:8080
# Set to false only for local HTTP dev; true in production (HTTPS) so cookies are Secure.
SECURE_COOKIES=true

# --- Database (Postgres DSN) ---
DB_CONNECTION_STRING=postgres://raai:raai@db:5432/raai?sslmode=disable
DB_PASSWORD=raai

# --- Auth / JWT (§5) ---
JWT_KEY=change-me-to-a-long-random-secret
JWT_ISSUER=raai
JWT_AUDIENCE=raai-app

# --- Billing / InstaPay (§7) ---
INSTAPAY_IPA=yourname@instapay
INSTAPAY_DISPLAY_NAME=Hazem Ahmed
PRICE_MONTHLY_EGP=1500
PRICE_YEARLY_EGP=15000

# Optional — only if you add §7.5 bank-notification ingestion.
BANK_NOTIFY_SHARED_SECRET=
